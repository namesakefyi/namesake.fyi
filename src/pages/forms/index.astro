---
import type { SanityDocument } from "@sanity/client";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import FormLink from "@/components/FormLink.astro";
import PageHeader from "@/components/PageHeader.astro";
import { getFormConfig } from "@/constants/forms";
import { getFormPdfMetadata } from "@/forms/getFormPdfMetadata";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { loadQuery } from "@/sanity/lib/loadQuery";
import { formatTimeEstimate } from "@/utils/formatTimeEstimate";

const { params } = Astro.props;

const { data: forms } = await loadQuery<SanityDocument[]>({
  query: `*[_type == "form" && defined(slug)]{
    title,
    slug,
    _updatedAt,
  } | order(publishDate desc)`,
  params,
});

// Get PDF metadata and step count for each form
const formsWithPdfs = await Promise.all(
  forms.map(async (form) => {
    const formSlug = form.slug.current;
    const config = getFormConfig(formSlug);
    const pdfs = config ? await getFormPdfMetadata(formSlug) : [];
    const stepCount = config?.steps.length ?? 0;
    const timeEstimate = formatTimeEstimate(stepCount);

    return {
      title: form.title,
      slug: form.slug,
      pdfs,
      stepCount,
      timeEstimate,
      updatedAt: form._updatedAt,
    };
  }),
);

dayjs.extend(utc);
---

<BaseLayout
  title="Forms"
  description="Namesake's guided forms can help you fill out all the name change documents you need to file."
  color="white"
>
  <PageHeader
    title="Forms"
    description="Namesake's guided forms can help you fill out all the name change documents you need to file."
  />
  <div class="forms">
    {
      formsWithPdfs.length ? (
        formsWithPdfs.map((form) => (
          <FormLink
            title={form.title}
            slug={form.slug.current}
            documentCount={form.pdfs.length}
            timeEstimate={form.timeEstimate}
            updatedAt={form.updatedAt}
          />
        ))
      ) : (
        <p>No forms found.</p>
      )
    }
  </div>
</BaseLayout>

<style>
  .forms {
    display: grid;
    gap: var(--space-m);
    padding-block-end: var(--space-2xl);
    grid-template-columns: 1fr 1fr;

    @media (width > 600px) {
      grid-template-columns: 1fr 1fr 1fr;
      gap: var(--space-l);
    }

    @media (width > 1000px) {
      grid-template-columns: 1fr 1fr 1fr 1fr;
    }
  }
</style>
