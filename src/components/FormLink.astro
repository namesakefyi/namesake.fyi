---
import {
  RiCheckLine,
  RiDraftLine,
  RiFileCheckLine,
  RiTimerLine,
} from "@remixicon/react";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";

dayjs.extend(utc);

interface Props {
  title: string;
  slug: string;
  documentCount: number;
  timeEstimate: string;
  updatedAt: string;
}

const { title, slug, documentCount, timeEstimate, updatedAt } = Astro.props;
---

<article class="form">
  <a href={`/forms/${slug}`} class="form-link">
    <h2>
      {title}
    </h2>
  </a>
  <ul class="form-metadata">
    <li
      class="form-status"
      data-form-slug={slug}
      data-time-estimate={timeEstimate}
      data-status="not-started"
      data-loading
    >
      <span class="form-status-content" data-status-content="not-started">
        <span class="visually-hidden">Estimated time: </span>
        <RiTimerLine />
        {timeEstimate}
      </span>
      <span class="form-status-content" data-status-content="in-progress">
        <span class="visually-hidden">Status: </span>
        <RiDraftLine />
        In progress
      </span>
      <span class="form-status-content" data-status-content="complete">
        <span class="visually-hidden">Status: </span>
        <RiCheckLine />
        Complete
      </span>
    </li>
    <li>
      <RiFileCheckLine />{" "}
      {`${documentCount} document${documentCount > 1 ? "s" : ""}`}
    </li>
    <li>Updated {dayjs.utc(updatedAt).format("MMM D, YYYY")}</li>
  </ul>
</article>

<script>
  import { getFormStatus } from "@/forms/getFormStatus";

  document
    .querySelectorAll<HTMLElement>("[data-form-slug].form-status")
    .forEach((el) => {
      const slug = el.dataset.formSlug;
      if (!slug) return;

      getFormStatus(slug)
        .then((status) => {
          if (status === "inProgress") {
            el.dataset.status = "in-progress";
          } else if (status === "complete") {
            el.dataset.status = "complete";
          }
          // null = not started, keep "not-started"
          delete el.dataset.loading;
        })
        .catch((err) => {
          console.error(
            `Failed to load form status for "${slug}" from IndexedDB:`,
            err,
          );
          delete el.dataset.loading;
        });
    });
</script>

<style>
  .form {
    position: relative;
    border: 1px solid var(--border-color);
    padding: var(--space-l) var(--space-l);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    aspect-ratio: 8.5 / 11;
    overflow: hidden;
    box-shadow:
      5px 5px 0 -3px var(--background-color),
      5px 5px 0 -2px var(--border-color),
      10px 10px 0 -5px var(--background-color),
      10px 10px 0 -4px var(--border-color);

    @media (hover: hover) {
      &:has(.form-link:hover),
      &:has(.form-link:focus) {
        box-shadow:
          6px 6px 0 -3px var(--background-color),
          6px 6px 0 -2px var(--border-color),
          12px 12px 0 -5px var(--background-color),
          12px 12px 0 -4px var(--border-color);
      }
    }

    @media (width < 600px) {
      padding: var(--space-m) var(--space-m);
      box-shadow:
        5px 5px 0 -3px var(--background-color),
        5px 5px 0 -2px var(--border-color);

      @media (hover: hover) {
        &:has(.form-link:hover),
        &:has(.form-link:focus) {
          box-shadow:
            6px 6px 0 -3px var(--background-color),
            6px 6px 0 -2px var(--border-color);
        }
      }
    }

    h2 {
      font-size: var(--step-1);
      line-height: var(--line-height-display);

      @media (width < 600px) {
        font-size: var(--step-0);
      }
    }
  }

  .form-link {
    text-decoration: none;
    color: var(--text-color);

    &:hover,
    &:focus {
      text-decoration: underline;
    }

    &::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
    }
  }

  .form-metadata {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin: 0;
    padding-inline-start: var(--space-m);
    font-size: var(--step--2);
    list-style: none;
    padding: 0;
    margin: 0;

    li {
      display: flex;
      align-items: center;
      gap: var(--space-2xs);

      svg {
        height: 1lh;
        width: 1lh;
        flex-shrink: 0;
      }
    }

    .form-status {
      display: flex;
    }

    .form-status[data-loading] {
      visibility: hidden;
    }

    .form-status-content {
      display: none;
      align-items: center;
      gap: var(--space-2xs);
    }

    .form-status[data-status="not-started"] [data-status-content="not-started"],
    .form-status[data-status="in-progress"] [data-status-content="in-progress"],
    .form-status[data-status="complete"] [data-status-content="complete"] {
      display: flex;
    }
  }
</style>
