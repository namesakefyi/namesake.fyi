{
  "name": "namesake",
  "type": "module",
  "version": "0.0.1",
  "license": "GPL-3.0",
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "astro dev --open",
    "start": "astro dev",
    "build": "pnpm pdf:schema && wrangler types && astro check && astro build",
    "build:only": "astro build",
    "preview": "wrangler types && astro preview",
    "astro": "astro",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format",
    "format:fix": "biome format --write",
    "check": "astro check && biome check",
    "check:fix": "astro check && biome check --write",
    "test": "vitest",
    "test:once": "vitest run",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --reporter=html",
    "check-links": "lychee --config .lychee.toml .",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "idb:add-migration": "node scripts/create-idb-migration.mjs",
    "pdf:clean": "node scripts/clean-pdf.mjs",
    "pdf:remove-fields": "node scripts/remove-pdf-fields.mjs",
    "pdf:rename-fields": "node scripts/rename-pdf-fields.mjs",
    "pdf:schema": "node scripts/extract-pdf-schema.mjs",
    "pdf:define": "node scripts/define-pdf.mjs",
    "pdf:nudge-fields": "node scripts/nudge-pdf-fields.mjs",
    "typegen": "sanity schema extract --enforce-required-fields && sanity typegen generate"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{astro,cjs,css,js,json,jsonc,jsx,mjs,ts,tsx}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "13.5.1",
    "@astrojs/markdoc": "^1.0.5",
    "@astrojs/markdown-remark": "7.1.2",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/react": "^5.0.5",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@axe-core/playwright": "^4.11.3",
    "@cantoo/pdf-lib": "^2.6.5",
    "@internationalized/date": "^3.12.0",
    "@maskito/core": "^5.2.2",
    "@portabletext/react": "^6.2.0",
    "@portabletext/types": "^4.0.2",
    "@remixicon/react": "^4.9.0",
    "@sanity/astro": "^3.4.0",
    "@sanity/client": "^7.22.0",
    "@sanity/codegen": "^6.1.0",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/types": "^5.25.1",
    "@sanity/ui": "^3.2.0",
    "@severo_bo/us-atlas-2023": "^4.0.0",
    "@xstate/react": "^6.1.0",
    "astro": "6.3.3",
    "astro-portabletext": "^0.13.0",
    "browserslist": "^4.28.2",
    "d3": "^7.9.0",
    "d3-geo": "^3.1.1",
    "d3-selection": "^3.0.0",
    "fathom-client": "^3.7.2",
    "groq": "^5.25.1",
    "idb": "^8.0.3",
    "language-name-map": "^0.3.0",
    "react": "^19.2.6",
    "react-aria-components": "^1.16.0",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "react-is": "^19.2.6",
    "react-lite-youtube-embed": "^3.5.1",
    "rough-notation": "^0.5.1",
    "sanitize-html": "^2.17.4",
    "sanity": "^5.25.1",
    "styled-components": "^6.4.1",
    "topojson-client": "^3.1.0",
    "typescript": "^6.0.3",
    "ua-parser-js": "^2.0.9",
    "xstate": "^5.31.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@clack/prompts": "^1.4.0",
    "@cloudflare/vitest-pool-workers": "^0.16.4",
    "@playwright/test": "^1.60.0",
    "@react-aria/test-utils": "1.0.0-beta.3",
    "@storybook/addon-links": "^10.4.0",
    "@storybook/addon-themes": "^10.4.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/builder-vite": "^10.4.0",
    "@storybook/react": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
